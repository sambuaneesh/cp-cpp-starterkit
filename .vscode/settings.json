{
  "C_Cpp.default.cppStandard": "c++20",
  "C_Cpp.default.compilerPath": "/usr/bin/g++",
  "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",

  "clangd.arguments": [
    "--compile-commands-dir=.",
    "--background-index"
  ],

  "editor.formatOnSave": false,
  "files.associations": {
    "*.h": "cpp",
    "*.hpp": "cpp",
    "*.cpp": "cpp",
    "bits/stdc++.h": "cpp"
  },

  "terminal.integrated.cwd": "${workspaceFolder}"
}