{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CP: Run current file",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/cprun",
      "args": ["${fileBasename}"],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "CP: Sanitize current file",
      "type": "shell",
      "command": "g++ -std=c++20 -g -O0 -Wall -Wextra -Wshadow -DLOCAL -fsanitize=address,undefined ${fileBasename} -o /tmp/cp_san && /tmp/cp_san",
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": "$gcc"
    }
  ]
}
